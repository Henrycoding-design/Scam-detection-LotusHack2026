# OPENAI_API_KEY: Optional placeholder for future backend/server wiring.
# The Chrome extension does NOT read this yet.
# For demo/debugging, the extension hard-codes its temporary key in
# scam-shield/scoring/openai.js, which is not production-safe.
OPENAI_API_KEY="MY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
