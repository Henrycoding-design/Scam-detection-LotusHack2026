{
  "manifest_version": 3,
  "name": "ScamShield",
  "version": "0.2.0",
  "description": "Real-time scam detection for every page you visit",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/ui.js", "content/scanner.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": "icon.png"
  },

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "side_panel": {
    "default_path": "sidebar/index.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
