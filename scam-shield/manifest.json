{
  "manifest_version": 3,
  "name": "ScamShield",
  "version": "0.1.0",
  "description": "Real-time scam detection for every page you visit",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs",
    "downloads",
    "webNavigation"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "https://spam.audent.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/scanner.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "side_panel": {
    "default_path": "assets/dashboard.html"
  }
}
