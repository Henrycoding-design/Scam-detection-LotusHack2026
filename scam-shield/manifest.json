{
  "manifest_version": 3,
  "name": "ScamShield",
  "version": "0.1.0",
  "description": "Real-time scam detection for every page you visit",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/scanner.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  },

  "side_panel": {
    "default_path": "dashboard/index.html"
  }
}
